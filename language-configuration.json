{
  "comments": {
    "lineComment": "`"
  },
  "brackets": [
    [
      "(",
      ")"
    ],
    [
      "[",
      "]"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "\"",
      "close": "\""
    },
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "[",
      "close": "]"
    }
  ],
  "surroundingPairs": [
    [
      "\"",
      "\""
    ],
    [
      "(",
      ")"
    ],
    [
      "[",
      "]"
    ]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(if\\b.*\\bthen\\b|for\\b|do\\b|repeat\\b|while\\b|function\\b|type\\b|select\\b).*",
    "decreaseIndentPattern": "^\\s*(endif\\b|next\\b|loop\\b|until\\b|endwhile\\b|endfunction\\b|endtype\\b|endselect\\b|case\\b|default\\b).*"
  }
}
